<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:vm="using:AvaloniaUI.ViewModels"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:views="using:AvaloniaUI.Views"
        mc:Ignorable="d" d:DesignWidth="800" d:DesignHeight="450"
        x:Class="AvaloniaUI.Views.MainWindow"
        x:DataType="vm:MainWindowViewModel"
        Icon="/Assets/logo.png"
        Title="To The Depths"
        Width="1000" Height="700">

    <Grid>
        <ContentControl Content="{Binding CurrentPage}" />
        <ContentControl Classes="GamePopup" IsVisible="{Binding IsLoadErrorVisible}">
    <StackPanel Spacing="20">
        <TextBlock Text="{Binding LoadErrorMessage}" 
                   FontSize="20" FontWeight="Bold" 
                   Foreground="White" 
                   VerticalAlignment="Center" 
                   HorizontalAlignment="Center"/>
        <Button Classes="MenuButton" Width="200" 
                Focusable="False"
                Content="BACK TO MENU" 
                Command="{Binding CloseLoadErrorCommand}"/>
    </StackPanel>
</ContentControl>
    </Grid>
</Window>
