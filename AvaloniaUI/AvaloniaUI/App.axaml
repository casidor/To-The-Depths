<Application xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:local="using:AvaloniaUI"
             x:Class="AvaloniaUI.App"
             RequestedThemeVariant="Default">
             <!-- "Default" ThemeVariant follows system theme variant. "Dark" or "Light" are other available options. -->

    <Application.DataTemplates>
        <local:ViewLocator/>
    </Application.DataTemplates>

    <Application.Resources>
    <ResourceDictionary>
        <FontFamily x:Key="GameFont">Cascadia Code, Consolas, Courier New, monospace</FontFamily>
        <SolidColorBrush x:Key="BrushText" Color="#C0C0C0"/>
        <SolidColorBrush x:Key="BrushAccent" Color="#F0C040"/>
        <SolidColorBrush x:Key="BrushHP" Color="#E24B4A"/>
        <SolidColorBrush x:Key="BrushGold" Color="#F0C040"/>
        <SolidColorBrush x:Key="BrushKey" Color="#40AAFF"/>
        <SolidColorBrush x:Key="BrushBackground" Color="#12121E"/>
    </ResourceDictionary>
</Application.Resources>

<Application.Styles>
    <FluentTheme />
    <Style Selector="TextBlock">
        <Setter Property="FontFamily" Value="{DynamicResource GameFont}"/>
        <Setter Property="Foreground" Value="{DynamicResource BrushText}"/>
        <Setter Property="FontSize" Value="14"/>
    </Style>
    <Style Selector="Window, UserControl">
        <Setter Property="Background" Value="{DynamicResource BrushBackground}"/>
    </Style>
        <Style Selector="ContentControl.GamePopup">
        <Setter Property="ZIndex" Value="100"/>
        <Setter Property="Template">
            <ControlTemplate>
                <Border Background="#A0000000">
                    <Border Background="#222" 
                            BorderBrush="{DynamicResource BrushAccent}" 
                            BorderThickness="2" 
                            CornerRadius="8" 
                            Padding="30"
                            HorizontalAlignment="Center" 
                            VerticalAlignment="Center">
                        
                        <ContentPresenter Content="{TemplateBinding Content}" />
                        
                    </Border>
                </Border>
            </ControlTemplate>
        </Setter>
    </Style>
    <Style Selector="Button.MenuButton">
			<Setter Property="Background" Value="#2A2A40"/>
			<Setter Property="Foreground" Value="White"/>
			<Setter Property="BorderBrush" Value="{DynamicResource BrushAccent}"/>
			<Setter Property="BorderThickness" Value="1"/>
			<Setter Property="Width" Value="200"/>
			<Setter Property="Height" Value="40"/>
			<Setter Property="HorizontalAlignment" Value="Center"/>
			<Setter Property="HorizontalContentAlignment" Value="Center"/>
			<Setter Property="VerticalContentAlignment" Value="Center"/>
			<Setter Property="Transitions">
				<Transitions>
					<BrushTransition Property="Background" Duration="0:0:0.2"/>
					<BrushTransition Property="BorderBrush" Duration="0:0:0.2"/>
				</Transitions>
			</Setter>
		</Style>

		<Style Selector="Button.MenuButton:pointerover /template/ ContentPresenter#PART_ContentPresenter">
			<Setter Property="Background" Value="#3D3D5C"/> 
			<Setter Property="BorderBrush" Value="White"/> 
			<Setter Property="TextBlock.Foreground" Value="White"/>
		</Style>

		<Style Selector="Button.MenuButton:pressed /template/ ContentPresenter#PART_ContentPresenter">
			<Setter Property="Background" Value="#1A1A2A"/> 
			<Setter Property="BorderBrush" Value="{DynamicResource BrushAccent}"/>
			<Setter Property="TextBlock.Foreground" Value="Gray"/>
		</Style>
</Application.Styles>
</Application>